# Copy this file to .env.local and fill in your Supabase credentials.
# Without these set, the site will run in DEMO MODE using an in-memory
# store that resets every time the server restarts (perfect for local dev).

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only key used by API routes to bypass RLS when inserting votes
# and running the monthly snapshot job. NEVER expose this on the client.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: a shared secret required by the /api/cron/snapshot endpoint
# so only your cron service (Vercel Cron, Upstash, etc.) can trigger it.
CRON_SECRET=
